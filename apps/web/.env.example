# URL of the API. Required — the web app calls it directly (CORS handles cross-origin).
# Dev: http://localhost:3000
# Prod: set to your deployed API origin (e.g. https://your-api.example.com).
VITE_API_URL=http://localhost:3000

# Public base used for generated short links. Defaults to window.location.origin if unset.
# Dev: http://localhost:3000 (short links redirect via the API directly).
# Prod: set to your short-domain origin if different from VITE_API_URL.
VITE_SHORT_URL_BASE=http://localhost:3000
